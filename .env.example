# ============================================
# Hermes Agent 环境变量配置
# ============================================

# --- LLM Provider 选择 ---
# deepseek | gemini
LLM_PROVIDER=deepseek

# --- DeepSeek（默认 provider）---
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Gemini（切换 LLM_PROVIDER=gemini 时生效）---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- 搜索服务 ---
SEARCH_API_KEY=
FIRECRAWL_API_KEY=
EXA_API_KEY=

# --- Gateway平台 ---
# ⚠️ 微信无需手动配置，使用欢迎菜单 "扫码连接微信" 即可
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_HOME_CHANNEL=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_HOME_CHANNEL=
